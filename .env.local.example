# ─── Database ─────────────────────────────────────────────────────────────────
# Neon:    postgresql://user:pass@ep-xxx.neon.tech/booking?sslmode=require
# Railway: postgresql://postgres:pass@containers-xxx.railway.app:5432/railway

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32

NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32-output"
NEXTAUTH_URL="http://localhost:3000"
# On Vercel: NEXTAUTH_URL="https://your-app.vercel.app"
